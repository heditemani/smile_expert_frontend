# =========================================================================
# CONFIGURATION SECURISÉE POUR L'ENVOI D'EMAILS VIA GMAIL SMTP
# =========================================================================

# Le serveur SMTP de Google (Ma tbadalhomch hedhom)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# L'adresse email Google du cabinet (Eli bech yeb3ath menha el server)
SMTP_USER=dentalclinic.tn@gmail.com

# LE MOT DE PASSE D'APPLICATION GENERÉ PAR GOOGLE (16 LETTRES)
# /!\ Attention: Ma t7ottch el mot de passe el 3adi mta3 l'email hna!
# Yelzmek t-générih mel "App Passwords" f sécurité mta3 el compte Google.
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# L'adresse email eli bech tousselha el notification mta3 el contact 
# (Tnajjem t7ott-ha hya betha dentalclinic.tn@gmail.com)
RECEIVER_EMAIL=dentalclinic.tn@gmail.com