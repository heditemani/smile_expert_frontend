# =========================================================================
# CONFIGURATION SECURISÉE POUR L'ENVOI D'EMAILS VIA GMAIL SMTP
# =========================================================================

# Le serveur SMTP de Google 
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# L'adresse email Google du cabinet 
SMTP_USER=dentalclinic.tn@gmail.com

# LE MOT DE PASSE D'APPLICATION GENERÉ PAR GOOGLE (16 LETTRES)
# Yelzmek t-générih mel "App Passwords" f sécurité mta3 el compte Google.
SMTP_PASS=xxxx_xxxx_xxxx_xxxx



RECEIVER_EMAIL=dentalclinic.tn@gmail.com