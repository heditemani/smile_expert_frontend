{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Bypass Check Options (L-hrouz mta3 l-build f Vercel) */
    "allowJs": true,           // Tkhallih ya9ra l-js w l-jsx men ghir machakel
    "checkJs": false,          // Maythabetch fil-ghaltat mta3 files l-JS
    "strict": false,           // Tna7i l-strict mode bech tsket l-errors tawa
    "noImplicitAny": false,    // May9ollekch 3lech mesh 3ati type l-ay variable
    "strictNullChecks": false, // Yna7i l-machakel mta3 null w undefined

    /* Linting */
    "noUnusedLocals": false,   // Mayet9ala9ch ken variable declared ama mesh mosta3mla
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}